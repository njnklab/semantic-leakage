<section id="phases">
  <div class="container">
    <div class="section-head">
      <div class="kicker">Interactive Phase Explorer</div>
      <h2>How control migrated across five pandemic phases.</h2>
      <p class="subtitle">Click each phase to compare what stayed stable and what changed in the symptom network's control architecture.</p>
    </div>
    <div class="phase-nav" id="phaseNav"></div>
    <div class="phase-content">
      <div class="phase-left">
        <div class="phase-meta">
          <div class="phase-badges" id="phaseBadges"></div>
          <h3 class="phase-headline" id="phaseSummary"></h3>
          <p class="phase-context" id="phaseNarrative"></p>
        </div>
        <div class="phase-compare">
          <div class="soft-card">
            <h4>What remains stable</h4>
            <p id="stableText"></p>
          </div>
          <div class="soft-card">
            <h4>What changes here</h4>
            <p id="changeText"></p>
          </div>
        </div>
      </div>
      <div class="phase-right">
        <div class="phase-svg-wrap">
          <svg id="networkSvg" viewBox="0 0 480 360" width="100%" height="auto" aria-label="Schematic module control network"></svg>
        </div>
        <div class="phase-legend">
          <span class="legend-chip"><span class="domain-dot" style="background: var(--str)"></span>STR</span>
          <span class="legend-chip"><span class="domain-dot" style="background: var(--emo)"></span>EMO</span>
          <span class="legend-chip"><span class="domain-dot" style="background: var(--csf)"></span>CSF</span>
          <span class="legend-chip"><span class="domain-dot" style="background: var(--spf)"></span>SPF</span>
          <span class="legend-note">Arrow thickness = relative control strength</span>
        </div>
        <div class="phase-figure figure-block">
          <img id="phaseFigure" src="/covid-mcn-site/figs/fig3.png" alt="Module control figure for current phase" loading="lazy" />
          <div class="figure-caption" id="phaseFigCaption">Fig. 3 — Module-level control flow across phases</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .phase-nav {
    display: flex;
    gap: 6px;
    margin-bottom: 24px;
    overflow-x: auto;
    padding-bottom: 4px;
  }

  .phase-btn {
    flex: 1;
    min-width: 140px;
    border: 1px solid var(--line);
    background: var(--paper);
    color: var(--ink);
    border-radius: var(--radius);
    padding: 14px 16px;
    text-align: left;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: var(--font-body);
    position: relative;
    overflow: hidden;
  }

  .phase-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--ink);
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  .phase-btn:hover { border-color: var(--ink); }

  .phase-btn.active {
    background: var(--ink);
    color: white;
    border-color: var(--ink);
    box-shadow: var(--shadow);
  }

  .phase-btn.active::after { transform: scaleX(1); }

  .phase-btn .name {
    font-weight: 700;
    font-size: 0.92rem;
    margin-bottom: 2px;
  }

  .phase-btn .meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    opacity: 0.7;
  }

  .phase-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .phase-left {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .phase-meta {
    padding: 24px;
    border-radius: var(--radius);
    background: var(--paper);
    border: 1px solid var(--line);
  }

  .phase-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .phase-headline {
    font-size: 1.15rem;
    margin-bottom: 8px;
    line-height: 1.35;
  }

  .phase-context {
    color: var(--muted);
    font-size: 0.92rem;
    margin-bottom: 0;
  }

  .phase-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .phase-right {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .phase-svg-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--bg);
  }

  .phase-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .legend-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .legend-note {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    opacity: 0.6;
    margin-left: auto;
  }

  .phase-figure {
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 768px) {
    .phase-content { grid-template-columns: 1fr; }
    .phase-compare { grid-template-columns: 1fr; }
    .phase-nav { flex-wrap: nowrap; }
  }
</style>

<script>
  interface Phase {
    key: string; label: string; date: string; sample: number;
    communities: string; regime: string; context: string;
    summary: string; stable: string; change: string;
    nodes: string[]; extraNode: string | null;
    edges: [string, string, number, string][];
  }

  const phases: Phase[] = [
    {
      key: 'early', label: 'Early', date: '2020-04 – 2020-07', sample: 518,
      communities: '4–5 modules', regime: 'Stress-centered',
      context: 'Abrupt restriction, uncertainty, school disruption, and acute threat appraisal.',
      summary: 'Stress-related circuitry dominates outgoing control, shaping downstream emotional and cognitive-social modules.',
      stable: 'The broad modular scaffold remains recognizable, organized into a small number of coherent symptom communities.',
      change: 'Stress has the clearest control advantage — the cleanest "acute-response regime" phase.',
      nodes: ['STR','EMO','CSF','SPF'], extraNode: null,
      edges: [['STR','EMO',1.0,''],['STR','CSF',0.86,''],['STR','SPF',0.56,''],['EMO','STR',0.32,'']]
    },
    {
      key: 'first', label: 'First Wave', date: '2020-07 – 2021-01', sample: 2321,
      communities: '4–5 modules', regime: 'Stress + physiological subcluster',
      context: 'Sustained disruption with stress still acting as the main organizing force.',
      summary: 'Stress remains the leading controller. A small physiological subcluster becomes visible without changing the four-domain interpretation.',
      stable: 'The same core architecture persists, reinforcing that phase-wise comparison is meaningful on a conserved scaffold.',
      change: 'Even when communities split visually, the higher-order interpretation remains stable.',
      nodes: ['STR','EMO','CSF','SPF'], extraNode: 'PHY',
      edges: [['STR','EMO',0.96,''],['STR','CSF',0.78,''],['STR','PHY',0.62,''],['SPF','CSF',0.34,'']]
    },
    {
      key: 'second', label: 'Second Wave', date: '2021-01 – 2022-01', sample: 4721,
      communities: '4–5 modules', regime: 'Beginning redistribution',
      context: 'The crisis is no longer only acute; control becomes less monopolized by stress alone.',
      summary: 'The network scaffold remains intact, but the control map begins to distribute more visibly across multiple domains.',
      stable: 'Community organization remains broadly similar, preserving the central scaffold claim.',
      change: 'The transition phase where the shift from dominance to broader governance begins to emerge.',
      nodes: ['STR','EMO','CSF','SPF'], extraNode: null,
      edges: [['STR','EMO',0.82,''],['STR','CSF',0.68,''],['SPF','EMO',0.52,''],['CSF','EMO',0.48,'']]
    },
    {
      key: 'omicron', label: 'Omicron', date: '2022-01 – 2023-01', sample: 4023,
      communities: '4–5 modules', regime: 'Distributed cross-domain',
      context: 'The system reflects chronic adaptation rather than only acute stress response.',
      summary: 'Control becomes more evenly shared across stress, cognitive-social, and self-perception/physiological domains.',
      stable: 'The architecture does not collapse or fragment into a qualitatively different system.',
      change: 'Supports the interpretation of a move toward multi-module governance under prolonged crisis.',
      nodes: ['STR','EMO','CSF','SPF'], extraNode: null,
      edges: [['STR','EMO',0.70,''],['SPF','EMO',0.66,''],['CSF','STR',0.54,''],['SPF','CSF',0.58,'']]
    },
    {
      key: 'post', label: 'Post-Omicron', date: '2023-01 – 2024-01', sample: 2598,
      communities: '4–5 modules', regime: 'Broad multi-module',
      context: 'Formal restrictions ease, but accumulated burden and adaptation continue to shape interaction.',
      summary: 'Greater boundary mixing with a broader, more distributed control pattern beyond early stress dominance.',
      stable: 'A persistent backbone of influential symptoms remains visible, supporting continuity across the full window.',
      change: 'The clearest phase for chronic adaptation, boundary mixing, and integrative leverage.',
      nodes: ['STR','EMO','CSF','SPF'], extraNode: null,
      edges: [['STR','EMO',0.64,''],['SPF','EMO',0.72,''],['CSF','STR',0.60,''],['CSF','SPF',0.52,'']]
    }
  ];

  const domainConfig: Record<string, { x: number; y: number; color: string }> = {
    STR: { x: 240, y: 60, color: '#CC79A7' },
    EMO: { x: 410, y: 180, color: '#E69F00' },
    CSF: { x: 240, y: 300, color: '#56B4E9' },
    SPF: { x: 70, y: 180, color: '#009E73' },
    PHY: { x: 370, y: 75, color: '#9EA33A' }
  };

  const phaseNav = document.getElementById('phaseNav')!;
  const phaseBadges = document.getElementById('phaseBadges')!;
  const phaseSummary = document.getElementById('phaseSummary')!;
  const phaseNarrative = document.getElementById('phaseNarrative')!;
  const stableText = document.getElementById('stableText')!;
  const changeText = document.getElementById('changeText')!;
  const svg = document.getElementById('networkSvg')! as unknown as SVGSVGElement;

  function makeBadge(label: string, value: string): HTMLElement {
    const div = document.createElement('div');
    div.className = 'badge';
    const span = document.createElement('span');
    span.textContent = label + ' ';
    const strong = document.createElement('strong');
    strong.textContent = value;
    div.appendChild(span);
    div.appendChild(strong);
    return div;
  }

  function createPhaseNav() {
    phases.forEach((phase, idx) => {
      const btn = document.createElement('button');
      btn.className = 'phase-btn' + (idx === 0 ? ' active' : '');
      btn.type = 'button';
      const nameDiv = document.createElement('div');
      nameDiv.className = 'name';
      nameDiv.textContent = phase.label;
      const metaDiv = document.createElement('div');
      metaDiv.className = 'meta';
      metaDiv.textContent = 'n=' + phase.sample.toLocaleString() + ' · ' + phase.regime;
      btn.appendChild(nameDiv);
      btn.appendChild(metaDiv);
      btn.addEventListener('click', () => setPhase(idx));
      phaseNav.appendChild(btn);
    });
  }

  function setPhase(idx: number) {
    [...phaseNav.children].forEach((el, i) => el.classList.toggle('active', i === idx));
    const phase = phases[idx];
    phaseBadges.replaceChildren(
      makeBadge('Period:', phase.date),
      makeBadge('Sample:', 'n=' + phase.sample.toLocaleString()),
      makeBadge('Modules:', phase.communities)
    );
    phaseSummary.textContent = phase.summary;
    phaseNarrative.textContent = phase.context;
    stableText.textContent = phase.stable;
    changeText.textContent = phase.change;
    renderNetwork(phase);
  }

  function renderNetwork(phase: Phase) {
    while (svg.firstChild) svg.removeChild(svg.firstChild);
    const ns = 'http://www.w3.org/2000/svg';

    const defs = document.createElementNS(ns, 'defs');
    const marker = document.createElementNS(ns, 'marker');
    marker.setAttribute('id', 'ah'); marker.setAttribute('markerWidth', '8');
    marker.setAttribute('markerHeight', '6'); marker.setAttribute('refX', '7');
    marker.setAttribute('refY', '3'); marker.setAttribute('orient', 'auto');
    const poly = document.createElementNS(ns, 'polygon');
    poly.setAttribute('points', '0 0, 8 3, 0 6');
    poly.setAttribute('fill', 'rgba(26,26,46,0.4)');
    marker.appendChild(poly);
    defs.appendChild(marker);
    svg.appendChild(defs);

    // Background
    const bg = document.createElementNS(ns, 'rect');
    bg.setAttribute('width', '480'); bg.setAttribute('height', '360');
    bg.setAttribute('rx', '12'); bg.setAttribute('fill', '#FAFAF7');
    svg.appendChild(bg);

    // Ring
    const ring = document.createElementNS(ns, 'circle');
    ring.setAttribute('cx', '240'); ring.setAttribute('cy', '180');
    ring.setAttribute('r', '120'); ring.setAttribute('fill', 'none');
    ring.setAttribute('stroke', '#e5e7eb'); ring.setAttribute('stroke-dasharray', '4 6');
    svg.appendChild(ring);

    // Edges
    phase.edges.forEach(([from, to, w]) => {
      const a = domainConfig[from]; const b = domainConfig[to];
      if (!a || !b) return;
      const path = document.createElementNS(ns, 'path');
      const mx = (a.x + b.x) / 2; const my = (a.y + b.y) / 2;
      const dx = b.x - a.x; const dy = b.y - a.y;
      const norm = Math.hypot(dx, dy) || 1;
      const cx = mx - (dy / norm) * 36; const cy = my + (dx / norm) * 36;
      path.setAttribute('d', `M ${a.x} ${a.y} Q ${cx} ${cy} ${b.x} ${b.y}`);
      path.setAttribute('fill', 'none');
      path.setAttribute('stroke', 'rgba(26,26,46,0.35)');
      path.setAttribute('stroke-width', String(1.5 + 5.5 * w));
      path.setAttribute('stroke-linecap', 'round');
      path.setAttribute('opacity', String(0.25 + 0.65 * w));
      path.setAttribute('marker-end', 'url(#ah)');
      svg.appendChild(path);
    });

    // Nodes
    const nodesToDraw = phase.extraNode ? [...phase.nodes, phase.extraNode] : [...phase.nodes];
    nodesToDraw.forEach(key => {
      const n = domainConfig[key]; if (!n) return;
      const r = key === 'PHY' ? 18 : 24;

      const halo = document.createElementNS(ns, 'circle');
      halo.setAttribute('cx', String(n.x)); halo.setAttribute('cy', String(n.y));
      halo.setAttribute('r', String(r + 12));
      halo.setAttribute('fill', n.color); halo.setAttribute('opacity', '0.12');
      svg.appendChild(halo);

      const circle = document.createElementNS(ns, 'circle');
      circle.setAttribute('cx', String(n.x)); circle.setAttribute('cy', String(n.y));
      circle.setAttribute('r', String(r));
      circle.setAttribute('fill', n.color);
      circle.setAttribute('stroke', 'white'); circle.setAttribute('stroke-width', '2.5');
      svg.appendChild(circle);

      const label = document.createElementNS(ns, 'text');
      label.setAttribute('x', String(n.x)); label.setAttribute('y', String(n.y + 4.5));
      label.setAttribute('font-size', key === 'PHY' ? '10' : '12');
      label.setAttribute('font-weight', '700');
      label.setAttribute('font-family', 'DM Mono, monospace');
      label.setAttribute('text-anchor', 'middle');
      label.setAttribute('fill', 'white');
      label.textContent = key;
      svg.appendChild(label);
    });

    // Phase label
    const phaseLabel = document.createElementNS(ns, 'text');
    phaseLabel.setAttribute('x', '20'); phaseLabel.setAttribute('y', '28');
    phaseLabel.setAttribute('font-size', '12'); phaseLabel.setAttribute('font-weight', '700');
    phaseLabel.setAttribute('font-family', 'DM Sans, sans-serif');
    phaseLabel.setAttribute('fill', '#1a1a2e');
    phaseLabel.textContent = phase.label + ' phase';
    svg.appendChild(phaseLabel);

    const regimeLabel = document.createElementNS(ns, 'text');
    regimeLabel.setAttribute('x', '20'); regimeLabel.setAttribute('y', '44');
    regimeLabel.setAttribute('font-size', '10'); regimeLabel.setAttribute('font-family', 'DM Mono, monospace');
    regimeLabel.setAttribute('fill', '#6b7280');
    regimeLabel.textContent = phase.regime;
    svg.appendChild(regimeLabel);
  }

  createPhaseNav();
  setPhase(0);
</script>
