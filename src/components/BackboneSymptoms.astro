<section id="backbone">
  <div class="container">
    <div class="section-head">
      <div class="kicker">Backbone Symptoms</div>
      <h2>Controlled migration around a persistent core.</h2>
      <p class="subtitle">Stable backbone controllers persist across phases, while macro context is carefully framed as associational, not causal.</p>
    </div>
    <div class="bb-layout">
      <div class="bb-left">
        <div class="panel bb-card">
          <h3>Backbone controllers</h3>
          <p class="bb-intro">These nodes remain relatively prominent across all five phases. Click to explore.</p>
          <div class="node-list" id="nodeList"></div>
          <div class="node-detail" id="nodeDetail">
            <p class="node-placeholder">Select a symptom above.</p>
          </div>
        </div>
        <figure class="fig-inline">
          <img src="/covid-mcn-site/figs/fig4-2.png" alt="Control frequency networks and alluvial flow across phases" loading="lazy" />
          <figcaption class="fig-cap">Fig. 4 — Control frequency, CV scatter, and alluvial flow of module dominance across phases</figcaption>
        </figure>
      </div>
      <div class="bb-right">
        <div class="panel ctx-card">
          <h3>Macro context</h3>
          <p class="bb-intro">Exploratory analysis situates network changes within policy and epidemiological time structure — without claiming causation.</p>
          <div class="ctx-items">
            <div class="ctx-row">
              <div class="ctx-bar" style="background: var(--str)"></div>
              <div>
                <h4>Policy variables appear more proximal than case counts</h4>
                <p>The organization of daily life may track youth symptoms more closely than epidemiological burden by itself.</p>
              </div>
            </div>
            <div class="ctx-row">
              <div class="ctx-bar" style="background: var(--emo)"></div>
              <div>
                <h4>Illustrative, not deterministic</h4>
                <p>Fear & Anxiety aligns with movement restrictions; Emotional Resilience shows a short-lag relationship with travel controls.</p>
              </div>
            </div>
            <div class="ctx-row">
              <div class="ctx-bar" style="background: var(--csf)"></div>
              <div>
                <h4>Language discipline throughout</h4>
                <p>"Tracked," "aligned with," and "provided context for" — never causal phrases.</p>
              </div>
            </div>
          </div>
        </div>
        <figure class="fig-inline">
          <img src="/covid-mcn-site/figs/fig5.png" alt="Macro-context and lagged associations" loading="lazy" />
          <figcaption class="fig-cap">Fig. 5 — Policy decoupling, lagged associations, and lag-lead heatmap</figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>

<style>
  .bb-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(16px, 3vw, 24px);
    align-items: start;
  }

  .bb-left, .bb-right {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .bb-card, .ctx-card { padding: clamp(16px, 2vw, 24px); }

  .bb-intro {
    color: var(--muted);
    font-size: clamp(0.82rem, 0.9vw, 0.92rem);
    margin-bottom: 14px;
  }

  .node-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 14px;
  }

  .node-chip {
    border: 1px solid var(--line);
    background: var(--paper);
    color: var(--ink);
    border-radius: 999px;
    padding: 7px 14px;
    font-weight: 600;
    font-size: clamp(0.76rem, 0.85vw, 0.84rem);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: var(--font-body);
  }

  .node-chip:hover { border-color: var(--ink); }
  .node-chip.active { background: var(--ink); color: white; border-color: var(--ink); }

  .node-detail {
    padding: clamp(14px, 2vw, 18px);
    border-radius: var(--radius);
    background: var(--bg);
    border: 1px solid var(--line);
    min-height: 140px;
  }

  .node-detail h3 { font-size: clamp(0.9rem, 1vw, 1rem); margin-bottom: 8px; }

  .node-tags {
    display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px;
  }

  .node-tag {
    font-family: var(--font-mono);
    font-size: clamp(0.66rem, 0.75vw, 0.74rem);
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--paper);
    border: 1px solid var(--line);
    color: var(--muted);
    font-weight: 500;
  }

  .node-placeholder { color: var(--muted); font-size: 0.88rem; margin: 0; }
  .node-detail p { font-size: clamp(0.82rem, 0.9vw, 0.9rem); color: var(--muted); line-height: 1.6; }

  .ctx-items { display: flex; flex-direction: column; gap: 10px; }

  .ctx-row {
    display: flex;
    gap: 12px;
    padding: clamp(12px, 1.5vw, 16px);
    border-radius: var(--radius);
    background: var(--bg);
    border: 1px solid var(--line);
  }

  .ctx-bar { width: 4px; border-radius: 2px; flex-shrink: 0; }
  .ctx-row h4 { font-size: clamp(0.82rem, 0.9vw, 0.9rem); margin-bottom: 4px; }
  .ctx-row p { font-size: clamp(0.78rem, 0.85vw, 0.86rem); color: var(--muted); margin-bottom: 0; line-height: 1.55; }

  @media (max-width: 768px) {
    .bb-layout { grid-template-columns: 1fr; }
  }
</style>

<script>
  interface NodeInfo { domain: string; role: string; why: string; use: string; }

  const nodeDetails: Record<string, NodeInfo> = {
    'Fear & Anxiety': { domain: 'STR', role: 'Backbone', why: 'Repeatedly influential across phases — anchors the claim that stable control nodes persist while system-level control reallocates.', use: 'A persistent stress-linked controller explaining continuity under prolonged disruption.' },
    'Anger & Irritability': { domain: 'STR / EMO', role: 'Backbone', why: 'Sits near major emotional-stress interfaces, showing why early stress dominance continues to matter as control distributes.', use: 'Cross-boundary symptom keeping affective pressure connected to wider system behavior.' },
    'Sadness & Hopelessness': { domain: 'EMO', role: 'Backbone', why: 'Repeated prominence shows emotional burden remains central even when the locus of outgoing control changes.', use: 'Connects the module story to clinically legible emotional outcomes.' },
    'Focus & Concentration': { domain: 'CSF', role: 'Backbone', why: 'Explains why later phases concern cognitive efficiency and day-to-day functioning, not only mood.', use: 'Evidence that cognitive/social function becomes an increasingly relevant control participant.' },
    'Emotional Resilience': { domain: 'EMO / adaptive', role: 'Backbone', why: 'Control is not only in overtly negative symptoms but also at adaptive-regulatory interfaces.', use: 'Bridge between risk-oriented interpretation and a broader regulation framework.' }
  };

  const nodeList = document.getElementById('nodeList')!;
  const nodeDetail = document.getElementById('nodeDetail')!;
  const names = Object.keys(nodeDetails);

  function setNode(name: string) {
    [...nodeList.children].forEach(el => el.classList.toggle('active', el.textContent === name));
    const node = nodeDetails[name];
    nodeDetail.replaceChildren();

    const h3 = document.createElement('h3'); h3.textContent = name; nodeDetail.appendChild(h3);

    const tags = document.createElement('div'); tags.className = 'node-tags';
    const dt = document.createElement('span'); dt.className = 'node-tag'; dt.textContent = node.domain;
    const rt = document.createElement('span'); rt.className = 'node-tag'; rt.textContent = node.role;
    tags.appendChild(dt); tags.appendChild(rt); nodeDetail.appendChild(tags);

    const wp = document.createElement('p');
    const ws = document.createElement('strong'); ws.textContent = 'Why: ';
    wp.appendChild(ws); wp.appendChild(document.createTextNode(node.why)); nodeDetail.appendChild(wp);

    const up = document.createElement('p'); up.style.marginBottom = '0';
    const us = document.createElement('strong'); us.textContent = 'Interpretation: ';
    up.appendChild(us); up.appendChild(document.createTextNode(node.use)); nodeDetail.appendChild(up);
  }

  names.forEach((name, idx) => {
    const btn = document.createElement('button');
    btn.className = 'node-chip' + (idx === 0 ? ' active' : '');
    btn.type = 'button'; btn.textContent = name;
    btn.addEventListener('click', () => setNode(name));
    nodeList.appendChild(btn);
  });
  setNode(names[0]);
</script>
