---
import fs from 'node:fs';
import path from 'node:path';

const normalizedBaseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

// Dataset metadata
const datasetMeta: Record<string, { 
  key: string; 
  label: string; 
  language: string; 
  sample: number; 
  duration: string;
  type: string;
  description: string;
  depressionMetric: string;
} > = {
  edaic: { 
    key: 'edaic', 
    label: 'E-DAIC', 
    language: 'English', 
    sample: 189, 
    duration: '~20 min',
    type: 'Semi-structured interview',
    description: 'Extended Distress Analysis Interview Corpus with PHQ-8 annotations. AVEC 2019 benchmark dataset.',
    depressionMetric: 'PHQ-8'
  },
  pdch: { 
    key: 'pdch', 
    label: 'PDCH', 
    language: 'Chinese', 
    sample: 100, 
    duration: '~30 min',
    type: 'Clinical consultation',
    description: 'Parallel Data of Depression Consultation with HAMD-17 annotations. Real-world clinical setting.',
    depressionMetric: 'HAMD-17'
  },
  cmdc: { 
    key: 'cmdc', 
    label: 'CMDC', 
    language: 'Chinese', 
    sample: 78, 
    duration: 'Variable',
    type: 'Semi-structured interview',
    description: 'Chinese Multimodal Depression Corpus with 26 depressed and 52 healthy controls.',
    depressionMetric: 'Clinical diagnosis'
  },
  mandic: { 
    key: 'mandic', 
    label: 'ManDIC', 
    language: 'Chinese', 
    sample: 557, 
    duration: '927s avg',
    type: 'Clinical interview',
    description: 'Mandarin Distress Interview Corpus collected at Nanjing Brain Hospital. This study contribution.',
    depressionMetric: 'HAMD-17'
  }
};

const manuscriptPdfUrl = `${normalizedBaseUrl}pdfs/main.pdf`;
const analysisRepoUrl = 'https://github.com/njnklab/';

// Color scheme for datasets
const datasetColorMap: Record<string, string> = {
  edaic: '#CC79A7',
  pdch: '#E69F00',
  cmdc: '#56B4E9',
  mandic: '#009E73'
};

// Key findings data
const keyFindings = [
  {
    id: 1,
    title: 'Semantic Leakage Verified',
    description: 'Removing cue spans consistently degrades performance across all baseline models, confirming that models exploit lexically explicit depression-related content.',
    metric: 'MAE increase: +0.09 to +0.51',
    dataset: 'All datasets'
  },
  {
    id: 2,
    title: 'Model-Dependent Leakage',
    description: 'Traditional ML models (SVM, RF) and multi-feature fusion networks (ABAFnet) show stronger cue dependence than raw-audio models like STFN.',
    metric: 'RF: +0.39 MAE, STFN: +0.003 MAE',
    dataset: 'E-DAIC'
  },
  {
    id: 3,
    title: 'CueGate Effectiveness',
    description: 'Lightweight CueGate module successfully identifies cue spans with high precision, enabling plug-and-play cue filtering for any downstream model.',
    metric: 'Frame-level F1: >0.85',
    dataset: 'Cross-dataset'
  },
  {
    id: 4,
    title: 'Cross-Lingual Consistency',
    description: 'Semantic leakage pattern holds across both English and Chinese clinical corpora, indicating a universal challenge in speech-based depression detection.',
    metric: 'Consistent Δ across languages',
    dataset: 'E-DAIC, PDCH, CMDC, ManDIC'
  }
];

// Method steps
const methodSteps = [
  {
    step: 1,
    title: 'Speech Interval Pruning',
    description: 'Voice Activity Detection (VAD) identifies speech-active regions, removing silence and interviewer segments to isolate participant speech.'
  },
  {
    step: 2,
    title: 'ASR Ensemble & Reconciliation',
    description: 'Multiple ASR systems produce candidate transcriptions. A proposer agent aggregates via confidence-weighted voting; a critic refines for consistency.'
  },
  {
    step: 3,
    title: 'Speaker Role Attribution',
    description: 'Diarization and turn-taking patterns label each segment as interviewer or participant, filtering to participant-only content.'
  },
  {
    step: 4,
    title: 'LLM-Based Cue Detection',
    description: 'Two-stage LLM pipeline: (1) detect candidate depression-related words, (2) verify and filter false positives using clinical criteria.'
  },
  {
    step: 5,
    title: 'Controlled Audio Reconstruction',
    description: 'Generate three variants: Pre (all speech), Cue-Only (cue spans only), No-Cue (cue spans removed) for controlled evaluation.'
  }
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Semantic Leakage in Speech-based Depression Detection — Paper Website</title>
  <meta name="description" content="Paper website for the manuscript: Semantic Leakage in Speech-based Depression Detection" />
  <style is:inline>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=IBM+Plex+Sans:wght@300;400;500&display=swap');

    :root {
      --bg: #f8fbff;
      --card: #ffffff;
      --accent: #1e40af;
      --text: #0f172a;
      --muted: #1f2937;
      --border: #c8d8ee;
      --footer-bg: #f0f6ff;
      --radius: 10px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'IBM Plex Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-weight: 400;
      line-height: 1.72;
      font-size: 17px;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, h4 { font-family: 'DM Serif Display', serif; font-weight: 400; line-height: 1.2; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; display: block; }
    button { font-family: inherit; cursor: pointer; }

    .wrap { width: min(1080px, calc(100vw - 48px)); margin: 0 auto; }
    .sec-label { font-size: 0.78rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.16em; color: var(--accent); margin-bottom: 12px; }
    .sec-title { font-size: clamp(1.6rem, 3.2vw, 2.4rem); margin-bottom: 12px; }
    .sec-sub { color: var(--muted); font-size: clamp(0.98rem, 1.08vw, 1.1rem); max-width: 60ch; line-height: 1.72; }

    /* ── Nav ── */
    .site-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(255,255,255,0.9); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%); border-bottom: 1px solid var(--border); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; }
    .nav-brand { display: flex; align-items: center; gap: 10px; color: var(--text); text-decoration: none; font-weight: 500; font-size: 0.88rem; }
    .nav-mark { width: 30px; height: 30px; border-radius: 7px; background: var(--accent); display: grid; place-items: center; font-weight: 500; font-size: 0.68rem; color: #fff; flex-shrink: 0; }
    .nav-links { display: flex; gap: 4px; }
    .nav-link { padding: 6px 14px; border-radius: 6px; color: var(--muted); font-size: 0.88rem; font-weight: 400; transition: all 0.2s; text-decoration: none; }
    .nav-link:hover, .nav-link.active { color: var(--text); background: rgba(29,78,216,0.09); text-decoration: none; }
    .nav-link.active { color: var(--accent); }

    /* ── Hero ── */
    .hero { min-height: 88vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 72px 24px 28px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; top: -40%; left: -20%; width: 140%; height: 140%; background: radial-gradient(ellipse at 50% 30%, rgba(29,78,216,0.08) 0%, transparent 60%); pointer-events: none; }
    .hero-overline { font-size: 0.76rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.22em; color: var(--accent); margin-bottom: 22px; opacity: 0; animation: fadeUp 0.8s 0.2s forwards; }
    .hero-title { font-size: clamp(2.2rem, 5vw, 3.5rem); line-height: 1.1; margin-bottom: 22px; opacity: 0; animation: fadeUp 0.8s 0.4s forwards; }
    .hero-title .amber { color: var(--accent); }
    .hero-sub { font-size: clamp(1rem, 1.2vw, 1.12rem); color: var(--muted); max-width: 64ch; margin-bottom: 26px; line-height: 1.72; opacity: 0; animation: fadeUp 0.8s 0.6s forwards; }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 28px; opacity: 0; animation: fadeUp 0.8s 0.7s forwards; }
    .hero-cta { display: inline-flex; align-items: center; justify-content: center; padding: 9px 16px; border: 1px solid var(--border); border-radius: 999px; color: var(--text); font-size: 0.84rem; font-weight: 500; letter-spacing: 0.01em; text-decoration: none; background: rgba(255,255,255,0.72); transition: border-color 0.2s, transform 0.2s, background 0.2s; }
    .hero-cta:hover { text-decoration: none; border-color: var(--accent); background: #fff; transform: translateY(-1px); }
    .hero-cta-icon { width: 14px; height: 14px; display: inline-flex; align-items: center; justify-content: center; margin-right: 8px; color: var(--accent); flex-shrink: 0; }
    .hero-cta-icon svg { width: 100%; height: 100%; display: block; }
    .hero-stats { display: flex; gap: clamp(24px, 5vw, 56px); margin-bottom: 30px; opacity: 0; animation: fadeUp 0.8s 0.8s forwards; }
    .h-stat { text-align: center; }
    .h-stat-num { font-family: 'DM Serif Display', serif; font-size: clamp(1.8rem, 3.5vw, 2.6rem); line-height: 1.1; }
    .h-stat-label { font-size: 0.78rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-top: 6px; }
    .hero-domains { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-bottom: 36px; opacity: 0; animation: fadeUp 0.8s 1.0s forwards; }
    .hdot { display: flex; align-items: center; gap: 6px; font-size: 0.84rem; color: var(--muted); }
    .hdot i { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    .scroll-arrow { position: absolute; bottom: 22px; left: 50%; transform: translateX(-50%); opacity: 0; animation: fadeUp 0.8s 1.2s forwards; display: inline-flex; flex-direction: column; align-items: center; gap: 6px; color: var(--muted); text-decoration: none; }
    .scroll-arrow small { font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--muted); opacity: 0.9; }
    .scroll-arrow i { display: block; width: 1px; height: 10px; background: var(--border); }
    .scroll-arrow span { display: block; width: 14px; height: 14px; border-right: 2px solid var(--muted); border-bottom: 2px solid var(--muted); transform: rotate(45deg); animation: bounce 1.8s infinite; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes bounce { 0%,100% { transform: rotate(45deg) translateY(0); } 50% { transform: rotate(45deg) translateY(8px); } }

    /* ── Cards ── */
    .s-card { background: var(--card); border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: var(--radius); padding: clamp(20px, 2.5vw, 28px); position: relative; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s; }
    .s-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
    .s-card-num { position: absolute; top: -8px; right: 12px; font-family: 'DM Serif Display', serif; font-size: 4rem; color: var(--accent); opacity: 0.07; line-height: 1; pointer-events: none; }
    .s-card h4 { font-size: clamp(1rem, 1.1vw, 1.12rem); margin-bottom: 8px; }
    .s-card p { font-size: clamp(0.86rem, 0.92vw, 0.94rem); color: var(--muted); line-height: 1.65; }

    /* ── Grid layouts ── */
    .g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .g3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .g4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
    .g12 { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(16px, 3vw, 32px); align-items: start; }

    /* ── Sections ── */
    .sec { padding: clamp(60px, 8vw, 100px) 0; }

    /* ── Figures ── */
    .fig-wrap { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); background: var(--card); }
    .fig-wrap img { width: 100%; display: block; }
    .fig-cap { padding: 10px 14px; font-size: 0.84rem; color: var(--muted); border-top: 1px solid var(--border); }

    /* ── Dataset Explorer ── */
    .dataset-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin: 36px 0; }
    .dataset-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: clamp(16px, 2vw, 22px); cursor: pointer; transition: all 0.3s; border-top: 3px solid transparent; }
    .dataset-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
    .dataset-card.active { border-top-color: var(--accent); box-shadow: 0 4px 20px rgba(29,78,216,0.15); }
    .dataset-card h4 { font-size: clamp(1rem, 1.1vw, 1.15rem); margin-bottom: 6px; }
    .dataset-meta { font-size: 0.76rem; color: var(--muted); margin-bottom: 10px; }
    .dataset-badge { display: inline-block; font-size: 0.68rem; padding: 3px 8px; border-radius: 999px; background: rgba(29,78,216,0.08); color: var(--muted); margin-right: 4px; }
    .dataset-card p { font-size: 0.84rem; color: var(--muted); line-height: 1.55; margin: 0; }

    /* ── Key Findings ── */
    .finding-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: clamp(18px, 2.5vw, 24px); transition: transform 0.3s, box-shadow 0.3s; }
    .finding-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
    .finding-num { font-family: 'DM Serif Display', serif; font-size: 2.5rem; color: var(--accent); opacity: 0.15; line-height: 1; margin-bottom: 8px; }
    .finding-card h4 { font-size: clamp(0.95rem, 1.05vw, 1.1rem); margin-bottom: 8px; }
    .finding-card p { font-size: 0.86rem; color: var(--muted); line-height: 1.6; margin-bottom: 10px; }
    .finding-metric { font-size: 0.78rem; color: var(--accent); font-weight: 500; }

    /* ── Methods ── */
    .pipeline-horizontal-wrap { overflow-x: auto; padding-bottom: 4px; }
    .pipeline-horizontal { display: flex; gap: 12px; min-width: 1120px; align-items: stretch; }
    .pipe-h-item { flex: 1 0 200px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--card); padding: 14px 14px 12px; position: relative; }
    .pipe-h-item:not(:last-child)::after { content: '→'; position: absolute; right: -10px; top: 22px; font-size: 18px; color: #94a3b8; z-index: 2; }
    .pipe-h-head { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .pipe-num { width: 26px; height: 26px; border-radius: 50%; background: var(--accent); display: grid; place-items: center; font-size: 0.68rem; font-weight: 500; color: var(--bg); flex-shrink: 0; }
    .pipe-h-item h5 { font-size: 0.86rem; font-weight: 500; color: var(--text); margin: 0; line-height: 1.35; }
    .pipe-h-item p { font-size: 0.8rem; color: var(--muted); line-height: 1.52; margin: 0; }

    /* ── Results Table ── */
    .results-table { width: 100%; border-collapse: collapse; font-size: 0.84rem; }
    .results-table th, .results-table td { padding: 10px 12px; text-align: left; border-bottom: 1px solid var(--border); }
    .results-table th { background: #f7fbff; font-weight: 500; color: var(--text); }
    .results-table td { color: var(--muted); }
    .results-table .delta { color: #dc2626; font-weight: 500; }

    /* ── Significance ── */
    .sig-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: clamp(20px, 2.5vw, 28px); border-top: 3px solid var(--accent); transition: transform 0.3s, box-shadow 0.3s; }
    .sig-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
    .sig-cat { font-size: 0.68rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.16em; color: var(--accent); margin-bottom: 12px; }
    .sig-card h4 { font-size: clamp(1rem, 1.1vw, 1.12rem); margin-bottom: 10px; }
    .sig-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.65; }

    /* ── Glossary ── */
    .gloss-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2px; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); }
    .gloss-item { padding: clamp(14px, 2vw, 20px); background: var(--card); }
    .gloss-term { font-family: 'DM Serif Display', serif; font-weight: 700; font-size: clamp(0.86rem, 0.96vw, 0.95rem); margin-bottom: 8px; }
    .gloss-item p { color: var(--muted); font-size: clamp(0.78rem, 0.86vw, 0.86rem); margin-bottom: 0; line-height: 1.6; }

    /* ── Footer ── */
    .site-footer { background: var(--footer-bg); padding: clamp(48px, 6vw, 80px) 0 40px; border-top: 1px solid var(--border); }
    .footer-label { font-size: 0.72rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.18em; color: var(--accent); margin-bottom: 20px; }
    .res-btn { display: flex; align-items: center; gap: 12px; padding: 16px 24px; border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); text-decoration: none; font-size: 0.9rem; flex: 1; min-width: 180px; transition: all 0.25s; }
    .res-btn:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); text-decoration: none; }
    .res-btn-icon { width: 36px; height: 36px; border-radius: 8px; background: rgba(29,78,216,0.1); display: grid; place-items: center; font-size: 0.7rem; font-weight: 500; color: var(--accent); flex-shrink: 0; }
    .res-btn-text span { display: block; font-size: 0.84rem; color: var(--muted); }
    .citation { font-size: 0.84rem; color: var(--muted); line-height: 1.6; border-top: 1px solid var(--border); padding-top: 24px; max-width: 60ch; font-family: 'IBM Plex Sans', monospace; }

    /* ── Scroll reveal ── */
    .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .stagger > * { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .stagger.visible > *:nth-child(1) { transition-delay: 0s; opacity: 1; transform: none; }
    .stagger.visible > *:nth-child(2) { transition-delay: 0.08s; opacity: 1; transform: none; }
    .stagger.visible > *:nth-child(3) { transition-delay: 0.12s; opacity: 1; transform: none; }
    .stagger.visible > *:nth-child(4) { transition-delay: 0.18s; opacity: 1; transform: none; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hero { min-height: 82vh; padding-top: 64px; }
      .hero-ctas { gap: 8px; }
      .hero-cta { width: 100%; max-width: 320px; }
      .hero-stats { gap: 20px; flex-wrap: wrap; justify-content: center; }
      .g2, .g12 { grid-template-columns: 1fr; }
      .g3, .g4 { grid-template-columns: 1fr; }
      .dataset-grid { grid-template-columns: 1fr; }
      .wrap { width: calc(100vw - 32px); }
      .pipeline-horizontal { min-width: 980px; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav class="site-nav">
  <div class="wrap nav-inner">
    <a href="#" class="nav-brand"><span class="nav-mark">SL</span> Xu &amp; Zhang · Nanjing Medical Univ.</a>
    <div class="nav-links">
      <a class="nav-link" href="#summary">Summary</a>
      <a class="nav-link" href="#datasets">Datasets</a>
      <a class="nav-link" href="#findings">Findings</a>
      <a class="nav-link" href="#methods">Methods</a>
      <a class="nav-link" href="#results">Results</a>
      <a class="nav-link" href="#impact">Impact</a>
      <a class="nav-link" href="#resources">Resources</a>
    </div>
  </div>
</nav>

<!-- 1 HERO -->
<section class="hero">
  <div class="hero-overline">IEEE Transactions on Affective Computing</div>
  <h1 class="hero-title">Semantic Leakage in<br/><span class="amber">Speech-based Depression Detection</span></h1>
  <p class="hero-sub">Speech-based depression detection models often claim to learn non-semantic vocal biomarkers, but interview audio contains explicit symptom statements that models can exploit as shortcuts. We present a cue-aware framework to quantify and mitigate this semantic leakage.</p>
  <div class="hero-ctas">
    <a class="hero-cta" href={manuscriptPdfUrl} target="_blank" rel="noopener noreferrer">
      <span class="hero-cta-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <path d="M8 15h8"></path>
          <path d="M8 11h3"></path>
        </svg>
      </span>
      Open Manuscript PDF
    </a>
    <a class="hero-cta" href={analysisRepoUrl} target="_blank" rel="noopener noreferrer">
      <span class="hero-cta-icon" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.01.44-2.53-.49-2.69-.94a2.82 2.82 0 0 0-1.16-1.56c-.39-.21-.94-.73-.01-.75.87-.01 1.49.8 1.7 1.13.99 1.67 2.57 1.2 3.2.92.1-.72.39-1.2.71-1.48-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.58.82-2.14-.08-.2-.36-1.02.08-2.12 0 0 .67-.22 2.2.82a7.48 7.48 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.14 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8 8 0 0 0 8 0Z"></path>
        </svg>
      </span>
      View Code & Data
    </a>
  </div>
  <div class="hero-stats">
    <div class="h-stat"><div class="h-stat-num">4</div><div class="h-stat-label">Clinical datasets</div></div>
    <div class="h-stat"><div class="h-stat-num">6</div><div class="h-stat-label">Baseline models</div></div>
    <div class="h-stat"><div class="h-stat-num">924</div><div class="h-stat-label">Total recordings</div></div>
